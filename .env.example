# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL only — /api/generate and /api/embeddings are appended automatically
OLLAMA_URL=http://localhost:11434

# ── PostgreSQL (pgvector) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=agent
DB_USER=agent_user
DB_PASSWORD=agent_pass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentpassword

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Max fix iterations per task (default: 3)
MAX_ITERATIONS=3
# Hard timeout in seconds for each generated code execution (default: 30)
CODE_TIMEOUT=30
# Directory where per-task output files are written
OUTPUT_DIR=output

# ── API security (required) ───────────────────────────────────────────────────
# Any strong random string — generate with: openssl rand -hex 32
AGENT_API_KEY=your-secret-key-here

# ── Anthropic (required) ──────────────────────────────────────────────────────
# Used by builder() and fixer() for code generation
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Anthropic model (optional) ────────────────────────────────────────────────
# Defaults to claude-sonnet-4-6 if not set
# ANTHROPIC_MODEL=claude-sonnet-4-6
